<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Personalización de Reporte de Órdenes de Compra para Cruz Roja Dominicana -->
    <template id="report_purchaseorder_document_cruzroja" inherit_id="purchase.report_purchaseorder_document">
        
        <!-- 1. Eliminar espacio en blanco entre header y proveedor -->
        <xpath expr="//div[@class='page']/div[@class='clearfix'][1]" position="attributes">
            <attribute name="style">margin-bottom: 0mm !important; padding-bottom: 0mm !important;</attribute>
        </xpath>
        
        <!-- Eliminar margen adicional del address -->
        <xpath expr="//div[@name='partner_header']" position="attributes">
            <attribute name="style">margin-top: 0mm !important; padding-top: 0mm !important;</attribute>
        </xpath>
        
        <!-- 2. Agregar fecha de orden y partner_ref en el header -->
        <xpath expr="//div[@id='informations']" position="inside">
            <!-- Fecha de la orden de compra -->
            <div class="col-auto" t-if="o.date_order" name="date_order_header">
                <strong>Fecha de la orden:</strong>
                <p class="m-0" t-field="o.date_order"/>
            </div>
            
            <!-- Referencia del proveedor (partner_ref) -->
            <div class="col-auto" t-if="o.partner_ref" name="partner_reference">
                <strong>Referencia de su orden:</strong>
                <p class="m-0" t-field="o.partner_ref"/>
            </div>
        </xpath>
        
        <!-- 3. Colocar ITBIS e Impuestos debajo del Total -->
        <xpath expr="//div[@id='total']" position="after">
            <div class="row" id="tax_details_cruzroja" style="margin-top: 5mm; border-top: 2px solid #000; padding-top: 3mm;">
                <div class="col-7"/>
                <div class="col-5">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <!-- Mostrar ITBIS -->
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-if="tax_totals and tax_totals.get('groups_by_subtotal')">
                                <t t-foreach="tax_totals.get('groups_by_subtotal', {}).get(tax_totals.get('subtotals', [{}])[0].get('name', ''), [])" t-as="tax_group">
                                    <t t-if="'ITBIS' in tax_group.get('tax_group_name', '') or 'IVA' in tax_group.get('tax_group_name', '')">
                                        <tr>
                                            <td>
                                                <strong>Impuesto e ITBIS debajo del Total:</strong>
                                            </td>
                                            <td class="text-end">
                                                <strong><span t-esc="tax_group.get('formatted_tax_group_amount', '')"/></strong>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>
                            
                            <!-- Mostrar Retenciones si existen -->
                            <t t-set="tax_lines" t-value="o.order_line.mapped('taxes_id')"/>
                            <t t-set="withholding_taxes" t-value="tax_lines.filtered(lambda t: any(word in t.name.lower() for word in ['retención', 'retencion', 'withholding']))"/>
                            <t t-if="withholding_taxes">
                                <tr class="border-top" style="border-top: 1px solid #dee2e6 !important;">
                                    <td colspan="2">
                                        <strong>Retenciones:</strong>
                                    </td>
                                </tr>
                                <t t-foreach="withholding_taxes" t-as="wh_tax">
                                    <t t-set="wh_amount" t-value="sum(o.order_line.filtered(lambda l: wh_tax in l.taxes_id).mapped(lambda l: sum(tax.compute_all(l.price_unit, l.order_id.currency_id, l.product_qty, l.product_id, l.order_id.partner_id)['taxes'], 0.0) if tax == wh_tax else 0.0 for tax in l.taxes_id))"/>
                                    <tr>
                                        <td>
                                            <span t-esc="wh_tax.name"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="formatLang(env, wh_amount, currency_obj=o.currency_id)"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </xpath>
        
        <!-- Agregar estilos CSS personalizados -->
        <xpath expr="//head" position="inside">
            <style>
                /* Eliminar márgenes del header */
                .clearfix {
                    margin-bottom: 0mm !important;
                    padding-bottom: 0mm !important;
                }
                
                /* Sección de impuestos */
                #tax_details_cruzroja {
                    margin-top: 5mm;
                    padding-top: 3mm;
                    border-top: 2px solid #000;
                }
                
                /* Formato compacto para información del proveedor */
                div[name="partner_header"] {
                    margin-top: 0mm !important;
                    padding-top: 0mm !important;
                }
            </style>
        </xpath>
        
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Personalización de Reporte de Facturas para Cruz Roja Dominicana -->
    <template id="report_invoice_document_cruzroja" inherit_id="account.report_invoice_document">
        
        <!-- 1. Eliminar espacio en blanco entre header y cliente/proveedor -->
        <xpath expr="//div[@class='page']/div[@class='clearfix'][1]" position="attributes">
            <attribute name="style">margin-bottom: 0mm !important; padding-bottom: 0mm !important;</attribute>
        </xpath>
        
        <!-- Eliminar margen adicional si existe -->
        <xpath expr="//div[@name='invoice_address']" position="attributes">
            <attribute name="style">margin-top: 0mm !important; padding-top: 0mm !important;</attribute>
        </xpath>
        
        <!-- 2. Agregar fecha de orden y partner_ref en el header -->
        <xpath expr="//div[@id='informations']" position="inside">
            <!-- Fecha de la factura en el header -->
            <div class="col-auto" t-if="o.invoice_date" name="invoice_date_header">
                <strong>Fecha de la orden:</strong>
                <p class="m-0" t-field="o.invoice_date"/>
            </div>
            
            <!-- Referencia del partner -->
            <div class="col-auto" t-if="o.partner_id.ref or o.ref" name="partner_reference">
                <strong>Referencia de su orden:</strong>
                <p class="m-0">
                    <span t-if="o.ref" t-field="o.ref"/>
                    <span t-elif="o.partner_id.ref" t-field="o.partner_id.ref"/>
                </p>
            </div>
        </xpath>
        
        <!-- 3. Colocar ITBIS e Impuestos debajo del Total -->
        <xpath expr="//div[@id='total']" position="after">
            <div class="row" id="tax_details_cruzroja" style="margin-top: 5mm; border-top: 2px solid #000; padding-top: 3mm;">
                <div class="col-7"/>
                <div class="col-5">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <!-- Mostrar ITBIS -->
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-if="tax_totals and tax_totals.get('groups_by_subtotal')">
                                <t t-foreach="tax_totals.get('groups_by_subtotal', {}).get(tax_totals.get('subtotals', [{}])[0].get('name', ''), [])" t-as="tax_group">
                                    <t t-if="'ITBIS' in tax_group.get('tax_group_name', '') or 'IVA' in tax_group.get('tax_group_name', '')">
                                        <tr>
                                            <td>
                                                <strong>Impuesto e ITBIS debajo del Total:</strong>
                                            </td>
                                            <td class="text-end">
                                                <strong><span t-esc="tax_group.get('formatted_tax_group_amount', '')"/></strong>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>
                            
                            <!-- Mostrar Retenciones si existen -->
                            <t t-set="withholding_lines" t-value="o.line_ids.filtered(lambda l: l.tax_line_id and any(word in l.tax_line_id.name.lower() for word in ['retención', 'retencion', 'withholding']))"/>
                            <t t-if="withholding_lines">
                                <tr class="border-top" style="border-top: 1px solid #dee2e6 !important;">
                                    <td colspan="2">
                                        <strong>Retenciones:</strong>
                                    </td>
                                </tr>
                                <t t-foreach="withholding_lines" t-as="wh_line">
                                    <tr>
                                        <td>
                                            <span t-field="wh_line.name"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="wh_line.price_total"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr class="border-top" style="border-top: 1px solid #000 !important;">
                                    <td>
                                        <strong>Total Retenido:</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong>
                                            <span t-esc="formatLang(env, sum(withholding_lines.mapped('price_total')), currency_obj=o.currency_id)"/>
                                        </strong>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </xpath>
        
        <!-- Agregar estilos CSS personalizados -->
        <xpath expr="//head" position="inside">
            <style>
                /* Eliminar márgenes del header */
                .clearfix {
                    margin-bottom: 0mm !important;
                    padding-bottom: 0mm !important;
                }
                
                /* Sección de impuestos */
                #tax_details_cruzroja {
                    margin-top: 5mm;
                    padding-top: 3mm;
                    border-top: 2px solid #000;
                }
                
                /* Formato compacto para información del cliente */
                div[name="invoice_address"] {
                    margin-top: 0mm !important;
                    padding-top: 0mm !important;
                }
            </style>
        </xpath>
        
    </template>
</odoo>

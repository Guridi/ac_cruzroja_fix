<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_purchaseorder_document_henca_layout_fix"
              inherit_id="purchase.report_purchaseorder_document"
              priority="10000000">

        <!-- Reemplaza solo el bloque de información -->
        <xpath expr="//div[@id='informations']" position="replace">
            <div id="informations" class="mt-4 mb-4">

                <!-- Fila 1: realizado por -->
                <div class="row">
                    <div t-if="o.user_id" class="col-12 mb-2">
                        <strong>Realizado Por:</strong>
                        <p t-field="o.user_id" class="m-0"/>
                    </div>
                </div>

                <!-- Fila 2: referencia ocupa el espacio restante + fecha a la derecha -->
                <div class="row align-items-start">
                    <div t-if="o.partner_ref" class="col">
                        <strong>La referencia de su orden:</strong>
                        <p t-field="o.partner_ref" class="m-0" style="word-break: break-word; white-space: normal;"/>
                    </div>
                </div>

                <!-- Fila 3: incoterm, si aplica -->
                <div class="row" t-if="o.incoterm_id">
                    <div class="col-12 mt-2">
                        <strong>Incoterm:</strong>
                        <p t-if="o.incoterm_location" class="m-0">
                            <span t-field="o.incoterm_id.code"/><br/>
                            <span t-field="o.incoterm_location"/>
                        </p>
                        <p t-else="" t-field="o.incoterm_id.code" class="m-0"/>
                    </div>
                </div>

            </div>
        </xpath>
        <xpath expr="//t[@t-set='address']/div[@t-field='o.partner_id']" position="before">
            <div class="mb-2" style="text-align: left;">
                <strong>Fecha de entrega:</strong><br/>
                <span t-field="o.date_order"/>
            </div>
        </xpath>

    </template>

    <template id="purchase_document_tax_totals_custom"
          inherit_id="purchase.document_tax_totals"
          priority="10000000">

            <xpath expr="." position="replace">
                <t t-if="tax_totals">
                    <!-- Subtotal -->
                    <tr class="border-black o_subtotal">
                        <td><strong>Subtotal</strong></td>
                        <td class="text-end">
                            <span t-esc="tax_totals.get('formatted_amount_untaxed', '')"/>
                        </td>
                    </tr>

                    <!-- Total -->
                    <tr class="border-black o_total">
                        <td><strong>Total</strong></td>
                        <td class="text-end">
                            <span t-esc="tax_totals.get('formatted_amount_total', '')"/>
                        </td>
                    </tr>

                    <!-- Impuestos debajo del total -->
                    <t t-foreach="tax_totals.get('groups_by_subtotal', {}).values()" t-as="tax_group_list">
                        <t t-foreach="tax_group_list" t-as="tax_group">
                            <tr style="background-color: transparent !important; color: #000 !important;">
                                <td style="background-color: transparent !important; color: #000 !important; vertical-align: middle; text-align: center;">
                                    <span t-esc="tax_group.get('tax_group_name', '')"/>
                                    <t t-if="tax_group.get('formatted_tax_group_base_amount')">
                                        en <span t-esc="tax_group.get('formatted_tax_group_base_amount')"/>
                                    </t>
                                </td>
                                <td class="text-end" style="background-color: transparent !important; color: #000 !important;">
                                    <span t-esc="tax_group.get('formatted_tax_group_amount', '')"/>
                                </td>
                            </tr>
                        </t>
                    </t>
                </t>
            </xpath>

    </template>
</odoo>